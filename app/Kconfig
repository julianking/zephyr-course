#[*] LED Subsystem  --->
#     LED blink sleep time (1s (medium))  --->
#     [ ] Advanced LED settings  --->
#          (100) LED brightness (0-100)
#          (500) LED fade duration (ms)
#          Expert settings  --->
#               [ ] Enable LED debugging
#               [ ] Custom blink pattern

menuconfig LED_SUBSYSTEM
    bool "LED Subsystem"
    default y

if LED_SUBSYSTEM

choice
    prompt "LED blink sleep time"
    default BLINK_SLEEP_1000MS

config BLINK_SLEEP_250MS
    bool "250 ms (v. fast)"

config BLINK_SLEEP_500MS
    bool "500 ms (fast)"

config BLINK_SLEEP_1000MS
    bool "1 s (medium)"

config BLINK_SLEEP_2000MS
    bool "2 s (slow)"

endchoice

config BLINK_SLEEP_TIME_MS
    int
    default 250 if BLINK_SLEEP_250MS
    default 500 if BLINK_SLEEP_500MS
    default 1000 if BLINK_SLEEP_1000MS
    default 2000 if BLINK_SLEEP_2000MS
    help
        Choose blink sleep time (the less the faster the blinking)

menuconfig LED_ADVANCED
    bool "Advanced LED settings"

if LED_ADVANCED

config LED_BRIGHTNESS
    int "LED brightness (0-100)"
    range 0 100
    default 100
    help
        Set led brightness in percent

config LED_FADE_DURATION
    int "LED fade duration (ms)"
    range 0 5000
    default 500
    help
        Set led fade duration in ms

menu "Expert settings"
    visible if LED_ADVANCED

config LED_DEBUG
    bool "Enable LED debugging"
    default n

config LED_CUSTOM_PATTERN
    bool "Custom blink pattern"
    default n

endmenu

endif # LED_ADVANCED

endif # LED_SUBSYSTEM

source "Kconfig.zephyr"